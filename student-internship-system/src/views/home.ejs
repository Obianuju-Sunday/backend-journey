<!DOCTYPE html>

<html>

<head>
    <title>Student Internship System</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            max-width: 800px;
            margin: 50px auto;
            padding: 20px;
            text-align: center;
        }

        .btn {
            display: inline-block;
            padding: 15px 30px;
            margin: 10px;
            background: #007bff;
            color: white;
            text-decoration: none;
            border-radius: 5px;
        }

        .btn:hover {
            background: #0056b3;
        }

        .section {
            margin-top: 30px;
        }
    </style>

</head>

<body>
    <h1>Student Internship & Skill Profiling System</h1>
    <p>Connecting students with internship opportunities</p>

    <div class="section">
        <a href="/auth/register-student" class="btn">Register as Student</a>
        <a href="/auth/register-organization" class="btn">Register as Organization</a>
    </div>

    <div class="section">
        <a href="/auth/login" class="btn">Login</a>
    </div>
</body>

</html>